<?xml version="1.0" encoding="UTF-8"?>
<interface>
	<requires lib="gtk" version="4.0"/>
	<object class="GtkAdjustment" id="linespace_adjustment">
		<property name="lower">0</property>
		<property name="upper">100</property>
		<property name="value">0</property>
		<property name="step-increment">0.1</property>
		<property name="page-increment">1</property>
	</object>
	<object class="GtkAdjustment" id="icon_size_adjustment">
		<property name="lower">0</property>
		<property name="upper">100</property>
		<property name="value">0</property>
		<property name="step-increment">0.1</property>
		<property name="page-increment">1</property>
	</object>

	<object class="GtkBox" id="settings_box">
		<property name="orientation">vertical</property>
		<property name="halign">fill</property>
		<property name="hexpand">True</property>
		<property name="valign">start</property>
		<property name="margin-bottom">0</property>
		<property name="margin-end">0</property>
		<property name="margin-start">0</property>
		<property name="margin-top">0</property>
		<property name="spacing">6</property>
		<child>
			<object class="GtkLabel">
				<property name="can-focus">False</property>
				<property name="justify">center</property>
				<property name="label" translatable="yes">Text extension</property>
				<property name="valign">baseline</property>
				<property name="xalign">0.5</property>
				<property name="margin-bottom">6</property>
			</object>
		</child>

		<child>
			<object class="GtkExpander" id="icon_expander">
				<property name="label" translatable="yes">Icon</property>
				<child>
					<object class="GtkBox">
						<property name="orientation">vertical</property>
						<property name="halign">fill</property>
						<property name="hexpand">True</property>
						<property name="valign">start</property>
						<property name="vexpand">True</property>
						<property name="spacing">6</property>
						<child>
							<object class="GtkBox">
								<property name="orientation">horizontal</property>
								<property name="halign">fill</property>
								<property name="hexpand">True</property>
								<property name="valign">start</property>
								<property name="vexpand">False</property>
								<property name="spacing">6</property>
								<child>
									<object class="GtkLabel">
										<property name="can-focus">False</property>
										<property name="justify">left</property>
										<property name="label" translatable="yes">Icon enable:</property>
										<property name="valign">baseline</property>
										<property name="xalign">0.5</property>
									</object>
								</child>
								<child>
									<object class="GtkSwitch" id="icon_enable_switch">
										<property name="halign">end</property>
										<property name="hexpand">True</property>
										<property name="valign">center</property>
									</object>
								</child>
							</object>
						</child>
						<child>
							<object class="GtkBox">
								<property name="orientation">horizontal</property>
								<property name="halign">fill</property>
								<property name="hexpand">True</property>
								<property name="valign">start</property>
								<property name="vexpand">False</property>
								<child>
									<object class="GtkLabel">
										<property name="can-focus">False</property>
										<property name="justify">left</property>
										<property name="label" translatable="yes">Icon:</property>
										<property name="halign">start</property>
										<property name="hexpand">True</property>
										<property name="valign">baseline</property>
										<property name="xalign">0.5</property>
									</object>
								</child>
								<child>
									<object class="GtkMenuButton" id="icon_menubutton">
										<property name="halign">end</property>
										<property name="hexpand">False</property>
										<property name="tooltip-text" translatable="yes">Set the icon</property>
										<property name="popover">
											<object class="GtkPopover" id="icon_popover">
												<property name="position">top</property>
												<property name="margin-bottom">12</property>
												<property name="margin-end">12</property>
												<property name="margin-start">12</property>
												<property name="margin-top">12</property>
												<child>
													<object class="GtkBox">
														<property name="orientation">vertical</property>
														<property name="halign">fill</property>
														<property name="hexpand">True</property>
														<property name="valign">start</property>
														<property name="vexpand">False</property>
														<child>
															<object class="GtkBox">
																<property name="orientation">horizontal</property>
																<property name="halign">fill</property>
																<property name="hexpand">True</property>
																<property name="valign">end</property>
																<property name="vexpand">False</property>
																<property name="margin-bottom">4</property>
																<property name="margin-end">4</property>
																<property name="margin-start">0</property>
																<property name="margin-top">4</property>
																<child>
																	<object class="GtkButton" id="icon_zoomout_button">
																		<property name="icon-name">zoom-out-symbolic</property>
																		<property name="halign">end</property>
																		<property name="hexpand">True</property>
																		<property name="valign">center</property>
																	</object>
																</child>
																<child>
																	<object class="GtkButton" id="icon_zoomin_button">
																		<property name="icon-name">zoom-in-symbolic</property>
																		<property name="halign">end</property>
																		<property name="hexpand">False</property>
																		<property name="valign">center</property>
																	</object>
																</child>
															</object>
														</child>
														<child>
															<object class="GtkScrolledWindow">
																<property name="can-focus">1</property>
																<property name="margin-top">6</property>
																<property name="width-request">300</property>
																<property name="height-request">226</property>
																<child>
																	<object class="GtkGridView" id="icon_gridview">
																		<property name="halign">fill</property>
																		<property name="hexpand">True</property>
																		<property name="valign">fill</property>
																		<property name="vexpand">True</property>
																	</object>
																</child>
															</object>
														</child>
														<child>
															<object class="GtkBox">
																<property name="orientation">horizontal</property>
																<property name="halign">fill</property>
																<property name="hexpand">True</property>
																<property name="valign">end</property>
																<property name="vexpand">False</property>
																<property name="margin-bottom">4</property>
																<property name="margin-end">4</property>
																<property name="margin-start">0</property>
																<property name="margin-top">4</property>
																<child>
																	<object class="GtkCheckButton" id="icon_usedefault_checkbutton">
																		<property name="halign">start</property>
																		<property name="hexpand">False</property>
																		<property name="valign">center</property>
																		<property name="label" translatable="yes">Use default</property>
																	</object>
																</child>
																<child>
																	<object class="GtkButton" id="icon_ok_button">
																		<property name="halign">end</property>
																		<property name="hexpand">True</property>
																		<property name="valign">center</property>
																		<property name="label" translatable="yes">Ok</property>
																	</object>
																</child>
															</object>
														</child>
													</object>
												</child>
											</object>
										</property>
										<property name="child">
											<object class="GtkImage" id="icon_image">
												<property name="icon-name">image-x-generic-symbolic</property>
											</object>
										</property>
									</object>
								</child>
							</object>
						</child>
						<child>
							<object class="GtkBox">
								<property name="orientation">horizontal</property>
								<property name="halign">fill</property>
								<property name="hexpand">True</property>
								<property name="valign">start</property>
								<property name="vexpand">False</property>
								<child>
									<object class="GtkLabel">
										<property name="can-focus">False</property>
										<property name="justify">left</property>
										<property name="label" translatable="yes">Icon size:</property>
										<property name="valign">baseline</property>
										<property name="xalign">0.5</property>
									</object>
								</child>
								<child>
									<object class="GtkSpinButton" id="icon_size_spinbutton">
										<property name="halign">end</property>
										<property name="hexpand">True</property>
										<property name="digits">1</property>
										<property name="width-chars">4</property>
										<property name="max-width-chars">4</property>
										<property name="numeric">True</property>
										<property name="orientation">horizontal</property>
										<property name="valign">center</property>
										<property name="adjustment">icon_size_adjustment</property>
									</object>
								</child>
							</object>
						</child>
						<child>
							<object class="GtkBox">
								<property name="orientation">horizontal</property>
								<property name="halign">fill</property>
								<property name="hexpand">True</property>
								<property name="valign">start</property>
								<property name="vexpand">False</property>
								<child>
									<object class="GtkLabel">
										<property name="can-focus">False</property>
										<property name="justify">left</property>
										<property name="label" translatable="yes">Icon color:</property>
										<property name="valign">baseline</property>
										<property name="xalign">0.5</property>
									</object>
								</child>
								<child>
									<object class="GtkColorButton" id="icon_color_button">
										<property name="halign">end</property>
										<property name="hexpand">True</property>
										<property name="valign">center</property>
										<property name="rgba">#9141AC</property>
										<property name="show-editor">False</property>
										<property name="use-alpha">True</property>
										<property name="tooltip-text" translatable="yes">Select a color</property>
									</object>
								</child>
							</object>
						</child>

					</object>
				</child>
			</object>
		</child>

		<child>
			<object class="GtkExpander" id="misc_expander">
				<property name="label" translatable="yes">Misc.</property>
				<child>
					<object class="GtkBox">
						<property name="orientation">vertical</property>
						<property name="halign">fill</property>
						<property name="hexpand">True</property>
						<property name="valign">start</property>
						<property name="vexpand">True</property>
						<property name="spacing">6</property>
						<child>
							<object class="GtkBox">
								<property name="orientation">horizontal</property>
								<property name="halign">fill</property>
								<property name="hexpand">True</property>
								<property name="valign">start</property>
								<property name="vexpand">False</property>
								<property name="spacing">6</property>
								<child>
									<object class="GtkLabel">
										<property name="can-focus">False</property>
										<property name="justify">left</property>
										<property name="label" translatable="yes">Text line space:</property>
										<property name="valign">baseline</property>
										<property name="xalign">0.5</property>
									</object>
								</child>
								<child>
									<object class="GtkSpinButton" id="linespace_spinbutton">
										<property name="halign">end</property>
										<property name="hexpand">True</property>
										<property name="digits">1</property>
										<property name="width-chars">4</property>
										<property name="max-width-chars">4</property>
										<property name="numeric">True</property>
										<property name="orientation">horizontal</property>
										<property name="valign">center</property>
										<property name="adjustment">linespace_adjustment</property>
									</object>
								</child>
							</object>
						</child>
						<child>
							<object class="GtkBox">
								<property name="orientation">horizontal</property>
								<property name="halign">fill</property>
								<property name="hexpand">True</property>
								<property name="valign">start</property>
								<property name="vexpand">False</property>
								<property name="spacing">6</property>
								<child>
									<object class="GtkLabel">
										<property name="can-focus">False</property>
										<property name="justify">left</property>
										<property name="label" translatable="yes">Text orientation:</property>
										<property name="valign">baseline</property>
										<property name="xalign">0.5</property>
									</object>
								</child>
								<child>
									<object class="GtkComboBox" id="text_orientation_combobox">
										<property name="halign">end</property>
										<property name="hexpand">True</property>
										<property name="valign">center</property>
									</object>
								</child>
							</object>
						</child>
					</object>
				</child>
			</object>
		</child>

	</object>
</interface>

